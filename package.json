{
  "name": "poketeams",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "clean": "npx eslint --fix . ; npx prettier --write .",
    "dev": "react-router dev",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "dotenv -- drizzle-kit generate",
    "db:migrate": "dotenv -- drizzle-kit migrate",
    "db:migrate:test:unit": "dotenv -e .env.test.unit -- drizzle-kit migrate",
    "db:migrate:test:e2e": "dotenv -e .env.test.e2e -- drizzle-kit migrate",
    "db:migrate:test": "npm run db:migrate:test:unit && npm run db:migrate:test:e2e",
    "db:seed": "dotenv -- tsx database/seeds/fixtures.ts",
    "pokeapi:download": "tsx database/seeds/pokeapi/downloadAll.ts",
    "pokeapi:validate": "tsx database/seeds/pokeapi/validate.ts",
    "pokeapi:seed": "dotenv -- tsx database/seeds/pokeapi/seed.ts",
    "pokeapi:sync": "dotenv -- tsx database/seeds/pokeapi/run.ts",
    "db:studio": "npx drizzle-kit studio",
    "test-db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test-db:down": "docker compose -f docker-compose.test.yml down",
    "test-db:logs": "docker compose -f docker-compose.test.yml logs -f postgres-test",
    "test-db:reset": "npm run test-db:down && npm run test-db:up",
    "start": "react-router-serve ./build/server/index.js",
    "test": "npm run test:unit && npm run test:e2e",
    "pretest:e2e": "npm run db:migrate:test:e2e",
    "test:e2e": "dotenv -e .env.test.e2e -- playwright test",
    "pretest:e2e:ui": "npm run db:migrate:test:e2e",
    "test:e2e:ui": "dotenv -e .env.test.e2e -- playwright test --ui",
    "pretest:unit": "npm run db:migrate:test:unit",
    "test:unit": "LOG_LEVEL=silent dotenv -e .env.test.unit -- vitest run",
    "pretest:unit:watch": "npm run db:migrate:test:unit",
    "test:unit:watch": "LOG_LEVEL=silent dotenv -e .env.test.unit -- vitest",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@react-router/node": "7.14.2",
    "@react-router/serve": "7.14.2",
    "@remix-run/file-storage": "^0.13.4",
    "classnames": "^2.5.1",
    "cryptr": "^6.4.0",
    "drizzle-orm": "^0.45.2",
    "form-data": "^4.0.5",
    "isbot": "^5.1.39",
    "mailgun.js": "^13.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "7.14.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "7.14.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.6"
  }
}
