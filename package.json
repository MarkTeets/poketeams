{
  "name": "poketeams",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "clean": "npx eslint --fix . ; npx prettier --write .",
    "dev": "react-router dev",
    "db:generate": "dotenv -- drizzle-kit generate",
    "db:migrate": "dotenv -- drizzle-kit migrate",
    "db:seed": "dotenv -- tsx database/seed.ts",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@react-router/node": "7.14.2",
    "@react-router/serve": "7.14.2",
    "classnames": "^2.5.1",
    "cryptr": "^6.4.0",
    "drizzle-orm": "^0.45.2",
    "form-data": "^4.0.5",
    "isbot": "^5.1.39",
    "mailgun.js": "^13.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "7.14.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "7.14.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/node": "^25",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10"
  }
