# Test fixtures — deliberately fake values, safe to commit.
# Used by `npm run test:e2e` against the local docker test DB on port 5434.
TEST_MODE="true"
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/poketeams_test_e2e"
AUTH_COOKIE_SECRET="test-auth-cookie-secret-do-not-use-in-prod"
SESSION_COOKIE_SECRET="test-session-cookie-secret-do-not-use-in-prod"
MAGIC_LINK_SECRET="test-magic-link-secret-do-not-use-in-prod"
ORIGIN="http://localhost:5174"
MAILGUN_API_KEY="test-mailgun-key-unused-in-test"
MAILGUN_DOMAIN="test-mailgun-domain-unused-in-test"
LOG_LEVEL="warn"
